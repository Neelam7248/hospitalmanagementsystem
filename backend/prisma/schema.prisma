generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  profileImage String?
  firstName String
  lastName  String
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}


model Patient {
  id        Int      @id @default(autoincrement())
  name      String
  age       Int
  gender    String
  createdAt DateTime @default(now())
}