generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  profileImage String?
  firstName String
  lastName  String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
}


model Patient {
  id        Int      @id @default(autoincrement())
  name      String
  age       Int
  gender    String
  createdAt DateTime @default(now())
}
enum Role {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  PATIENT
}
model Doctor {
  id              String   @id @default(cuid())

  firstName       String
  lastName        String

  email           String   @unique
  phone           String   @unique

  gender          Gender

  specialization  String

  experience      Int

  qualification   String

  consultationFee Decimal  @db.Decimal(10,2)

  profileImage    String?

  address         String?

  city            String?

  state           String?

  country         String?

  postalCode      String?

  isAvailable     Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
enum Gender {
  MALE
  FEMALE
  OTHER
}